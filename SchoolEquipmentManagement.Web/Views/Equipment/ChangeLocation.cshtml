@model SchoolEquipmentManagement.Web.ViewModels.Equipment.EquipmentChangeLocationViewModel

@{
    ViewData["Title"] = "Смена местоположения";
}

<section class="hero-panel">
    <h1 class="display-title">Смена местоположения</h1>
    <p class="page-intro">Укажите новое место размещения оборудования и при необходимости оставьте комментарий.</p>
    <div class="hero-actions">
        <a asp-action="Details" asp-route-id="@Model.EquipmentId" class="btn btn-outline-secondary">К карточке</a>
    </div>
</section>

<section class="surface-card mb-3">
    <div class="inline-summary">
        <span>Инвентарный номер: <strong>@Model.InventoryNumber</strong></span>
        <span>Наименование: <strong>@Model.Name</strong></span>
        <span>Текущее местоположение: <strong>@Model.CurrentLocation</strong></span>
    </div>
</section>

<section class="surface-card">
    <form asp-action="ChangeLocation" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input asp-for="EquipmentId" type="hidden" />
        <input asp-for="InventoryNumber" type="hidden" />
        <input asp-for="Name" type="hidden" />
        <input asp-for="CurrentLocationId" type="hidden" />
        <input asp-for="CurrentLocation" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="NewLocationId" class="form-label"></label>
            <select asp-for="NewLocationId" asp-items="Model.AvailableLocations" class="form-select">
                <option value="">Выберите местоположение</option>
            </select>
            <span asp-validation-for="NewLocationId" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Comment" class="form-label"></label>
            <textarea asp-for="Comment" class="form-control" rows="4" placeholder="Например: перенесено в главный корпус, кабинет 203"></textarea>
            <span asp-validation-for="Comment" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Details" asp-route-id="@Model.EquipmentId" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model SchoolEquipmentManagement.Web.ViewModels.Auth.VerifyTwoFactorViewModel
@{
    ViewData["Title"] = "Подтверждение входа";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Подтверждение входа</h1>
                    <p class="text-muted mb-0">Введите код из письма, отправленного на адрес @(Model.DestinationHint ?? "вашу почту").</p>
                </div>

                <form asp-action="VerifyTwoFactor" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="ChallengeToken" type="hidden" />
                    <input asp-for="ReturnUrl" type="hidden" />
                    <input asp-for="RememberMe" type="hidden" />
                    <input asp-for="DestinationHint" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Подтвердить вход</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model SchoolEquipmentManagement.Web.ViewModels.Inventory.InventoryCheckViewModel

<section class="surface-card mb-3">
    <div class="inline-summary">
        <span>Инвентарный номер: <strong>@Model.InventoryNumber</strong></span>
        <span>Наименование: <strong>@Model.Name</strong></span>
        <span>Ожидаемое место: <strong>@Model.ExpectedLocationName</strong></span>
        <span>Статус: <strong>@Model.EquipmentStatusName</strong></span>
    </div>
</section>

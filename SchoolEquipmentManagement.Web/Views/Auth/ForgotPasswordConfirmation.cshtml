@{
    ViewData["Title"] = "Проверьте почту";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-3">Проверьте почту</h1>
                <p class="text-muted mb-4">Если учетная запись найдена и для нее настроен адрес электронной почты, мы отправили письмо с инструкцией для сброса пароля.</p>
                <a asp-action="Login" class="btn btn-primary">Вернуться ко входу</a>
            </div>
        </div>
    </div>
</div>

@model SchoolEquipmentManagement.Web.ViewModels.Equipment.EquipmentWarrantyReportViewModel

@{
    ViewData["Title"] = "Отчет по гарантиям";
}

<section class="hero-panel">
    <h1 class="display-title">Отчет по гарантиям</h1>
    <p class="page-intro">Отдельная выборка по гарантийным срокам: истекающие гарантии, уже истекшие позиции и общий гарантийный риск по реестру.</p>
    <div class="hero-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">К реестру</a>
        <a asp-action="DownloadWarrantyReportCsv" asp-route-warrantyFilter="@Model.WarrantyFilter" class="btn btn-primary">Скачать CSV для импорта</a>
    </div>
</section>

<section class="surface-card mb-4">
    <div class="surface-card-header">
        <div>
            <h2 class="surface-card-title">Фильтр отчета</h2>
            <div class="surface-card-subtitle">Можно быстро выделить позиции с истекающей или уже просроченной гарантией.</div>
        </div>
        <div class="metric-helper">Найдено: <strong>@Model.TotalCount</strong></div>
    </div>

    <form method="get" class="row g-3">
        <div class="col-lg-4">
            <label class="form-label" for="warrantyFilter">Гарантийный интервал</label>
            <select id="warrantyFilter" name="warrantyFilter" class="form-select" asp-items="Model.WarrantyFilters"></select>
        </div>
        <div class="col-lg-3 d-grid">
            <label class="form-label d-none d-lg-block">&nbsp;</label>
            <button type="submit" class="btn btn-primary">Применить</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.WarrantyFilter))
        {
            <div class="col-lg-3 d-grid">
                <label class="form-label d-none d-lg-block">&nbsp;</label>
                <a asp-action="WarrantyReport" class="btn btn-outline-secondary">Сбросить фильтр</a>
            </div>
        }
    </form>
</section>

<section class="table-shell">
    <div class="surface-card-header">
        <div>
            <h2 class="surface-card-title">Гарантийная выборка</h2>
            <div class="surface-card-subtitle">Список оборудования с гарантийной датой и оценкой риска.</div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Инвентарный номер</th>
                    <th>Объект</th>
                    <th>Статус</th>
                    <th>Гарантия</th>
                    <th>Риск</th>
                    <th>Ответственный</th>
                    <th class="text-center">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.InventoryNumber</td>
                            <td>
                                <div class="fw-semibold">@item.Name</div>
                                <div class="text-muted small">@item.EquipmentType</div>
                                <div class="text-muted small">@item.Location</div>
                            </td>
                            <td><span class="badge @item.StatusBadgeClass">@item.Status</span></td>
                            <td>
                                <div class="fw-semibold">@item.DisplayWarrantyEndDate</div>
                                <div class="text-muted small">@item.WarrantySummary</div>
                            </td>
                            <td><span class="badge @item.WarrantyRiskBadgeClass">@item.WarrantyRisk</span></td>
                            <td>@item.DisplayResponsiblePerson</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Карточка</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Изменить</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="fw-semibold mb-2">По выбранному гарантийному фильтру оборудование не найдено</div>
                            <div class="text-muted">Попробуйте изменить интервал или сбросить фильтр отчета.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

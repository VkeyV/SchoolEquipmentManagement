@model SchoolEquipmentManagement.Web.ViewModels.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Восстановление доступа";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Восстановление доступа</h1>
                    <p class="text-muted mb-0">Укажите логин или электронную почту. Мы отправим письмо с кодом и ссылкой для сброса пароля.</p>
                </div>

                <form asp-action="ForgotPassword" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="LoginOrEmail" class="form-label"></label>
                        <input asp-for="LoginOrEmail" class="form-control" autocomplete="username email" />
                        <span asp-validation-for="LoginOrEmail" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary">Отправить письмо</button>
                        <a asp-action="Login" class="btn btn-outline-secondary">Ко входу</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

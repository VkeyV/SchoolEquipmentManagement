@model SchoolEquipmentManagement.Web.ViewModels.Equipment.EquipmentIssuesIndexViewModel

@{
    ViewData["Title"] = "Проблемные объекты";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<section class="hero-panel">
    <h1 class="display-title">Проблемные объекты</h1>
    <p class="page-intro">Единый список оборудования, которое требует внимания: ремонт, диагностика, расхождения по инвентаризации и объекты, не найденные при проверке.</p>
    <div class="hero-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">К реестру</a>
    </div>
</section>

<partial name="_OperationAlerts" />

<section class="surface-card mb-4">
    <div class="surface-card-header">
        <div>
            <h2 class="surface-card-title">Сводка по проблемам</h2>
            <div class="surface-card-subtitle">Всего проблемных записей: @Model.TotalIssues.</div>
        </div>
    </div>

    @if (Model.HasIssues)
    {
        <div class="row g-3">
            @foreach (var group in Model.Groups)
            {
                <div class="col-md-6 col-xl-3">
                    <div class="p-3 rounded-4 border h-100 @group.AccentClass">
                        <div class="small text-uppercase fw-semibold mb-2">@group.Title</div>
                        <div class="display-6 fw-bold mb-2">@group.Count</div>
                        <div class="small">@group.Description</div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-muted">Проблемные объекты пока не обнаружены.</div>
    }
</section>

@if (Model.HasIssues)
{
    @foreach (var group in Model.Groups)
    {
        <section class="table-shell mb-4">
            <div class="surface-card-header">
                <div>
                    <h2 class="surface-card-title">@group.Title</h2>
                    <div class="surface-card-subtitle">@group.Description</div>
                </div>
                <div class="metric-helper">Объектов: <strong>@group.Count</strong></div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Инвентарный номер</th>
                            <th>Объект</th>
                            <th>Состояние</th>
                            <th>Приоритет</th>
                            <th>Ответственный</th>
                            <th>Комментарий</th>
                            <th class="text-center">Быстрые действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in group.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.InventoryNumber</td>
                                <td>
                                    <div class="fw-semibold">@item.Name</div>
                                    <div class="text-muted small">@item.EquipmentType</div>
                                    <div class="text-muted small">Учетное место: @item.Location</div>
                                    @if (!string.IsNullOrWhiteSpace(item.ActualLocationName))
                                    {
                                        <div class="text-muted small">Фактически: @item.DisplayActualLocation</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @item.StatusBadgeClass">@item.Status</span>
                                    <div class="text-muted small mt-2">Последняя проверка: @item.DisplayLastCheckedAt</div>
                                    <div class="text-muted small">Кто проверял: @item.DisplayLastCheckedBy</div>
                                </td>
                                <td>
                                    <span class="badge @item.PriorityBadgeClass">@item.PriorityLabel</span>
                                </td>
                                <td>@item.DisplayResponsiblePerson</td>
                                <td class="small">@item.IssueDescription</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                        <a asp-action="Details" asp-route-id="@item.EquipmentId" class="btn btn-sm btn-outline-primary">Открыть карточку</a>
                                        @if (item.CanChangeStatus)
                                        {
                                            <a asp-action="ChangeStatus" asp-route-id="@item.EquipmentId" class="btn btn-sm btn-outline-warning">Сменить статус</a>
                                        }
                                        @if (item.CanAssignResponsible)
                                        {
                                            <a asp-action="AssignResponsible"
                                               asp-route-id="@item.EquipmentId"
                                               asp-route-returnUrl="@returnUrl"
                                               class="btn btn-sm btn-outline-secondary">Назначить ответственного</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
}

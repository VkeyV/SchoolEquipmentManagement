@model SchoolEquipmentManagement.Web.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Вход в систему</h1>
                    <p class="text-muted mb-0">Используйте учетную запись сотрудника для доступа к реестру, инвентаризации и защищенным операциям.</p>
                </div>

                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" autocomplete="username" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                        <a asp-action="ForgotPassword" class="small">Забыли пароль?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Войти</button>
                </form>

                <hr class="my-4" />

                <div class="small text-muted">
                    <div class="fw-semibold text-dark mb-2">Тестовые учетные записи</div>
                    <div><code>admin</code> / <code>Admin123!</code></div>
                    <div><code>tech</code> / <code>Tech123!</code></div>
                    <div><code>responsible</code> / <code>Responsible123!</code></div>
                    <div><code>viewer</code> / <code>Viewer123!</code></div>
                    <div class="mt-2">Для восстановления доступа и 2FA у пользователя должна быть настроена электронная почта.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@{
    ViewData["Title"] = "Пароль обновлен";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-3">Пароль обновлен</h1>
                <p class="text-muted mb-4">Пароль успешно изменен. Теперь можно войти в систему с новым паролем.</p>
                <a asp-action="Login" class="btn btn-primary">Перейти ко входу</a>
            </div>
        </div>
    </div>
</div>

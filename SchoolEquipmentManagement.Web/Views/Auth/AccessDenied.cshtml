@model string
@{
    ViewData["Title"] = "Доступ запрещён";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-9 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-3">Недостаточно прав</h1>
                <p class="text-muted mb-3">У текущей роли нет доступа к этому разделу или действию.</p>

                @if (!string.IsNullOrWhiteSpace(Model))
                {
                    <p class="small text-muted mb-4">Запрошенный путь: <code>@Model</code></p>
                }

                <div class="d-flex gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">На главную</a>
                    <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-secondary">К реестру</a>
                </div>
            </div>
        </div>
    </div>
</div>
